version: 2
updates:
  # Python pip 패키지 매니저 설정
  - package-ecosystem: "pip"
    
    # requirements.txt 또는 setup.py 파일이 있는 루트 디렉토리
    directory: "/"
    
    schedule:
      # 매일 자동으로 검사 (한국 시간 기준 새벽 시간대 설정 추천)
      interval: "daily"
      time: "03:00"
      timezone: "Asia/Seoul"
      
    # 한 번에 열 수 있는 최대 Pull Request 개수 제한 (기본값 5)
    open-pull-requests-limit: 10
